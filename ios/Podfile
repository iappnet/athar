# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  suppressed_warning_targets = %w[
    DKImagePickerController
    DKPhotoGallery
    file_picker
    firebase_core
    firebase_messaging
    geocoding_ios
    home_widget
    workmanager_apple
    local_auth_darwin
    permission_handler_apple
    purchases_flutter
    purchases_ui_flutter
    RevenueCat
    RevenueCatUI
    share_plus
    SwiftyGif
    device_info_plus
    flutter_image_compress_common
    flutter_local_notifications
    geolocator_apple
    image_picker_ios
    libwebp
    open_filex
    SDWebImage
    SDWebImageWebPCoder
    sign_in_with_apple
  ]

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # ✅ توحيد deployment target
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'

      # ✅ Fix: prevents Xcode from injecting get-task-allow into pod frameworks
      # (that entitlement is only valid on app binaries, not frameworks —
      # injecting it caused 0xe8008014 at install time and KERN_CODESIGN_ERROR
      # at runtime in DartWorker thread)
      config.build_settings['CODE_SIGN_INJECT_BASE_ENTITLEMENTS'] = 'NO'

      # ✅ Fix: Flutter plugin pods whose public Obj-C headers import Flutter
      # (e.g. #include <Flutter/Flutter.h>) fail the module verifier because
      # Flutter.framework is not in the verifier's module search path.
      # flutter_additional_ios_build_settings does not disable this, so we do
      # it globally here — it's a build-time validation step only, not runtime.
      config.build_settings['ENABLE_MODULE_VERIFIER'] = 'NO'

      if suppressed_warning_targets.include?(target.name)
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      end

      # Suppress libtool "dummy.o has no symbols" warning from empty Flutter plugin pods
      if target.name == 'firebase_core'
        config.build_settings['OTHER_LIBTOOLFLAGS'] = '-no_warning_for_no_symbols'
      end

      # Fix: geolocator_apple header uses @import Flutter when Clang modules are on,
      # but Flutter's module map is not accessible in that context → "module not found".
      # Disabling modules makes __has_feature(modules) return false, so the plugin
      # falls through to the standard #import <Flutter/Flutter.h> path instead.
      if target.name == 'geolocator_apple'
        config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
        config.build_settings['DEFINES_MODULE'] = 'NO'
        # geolocator_apple.podspec omits CoreLocation/UIKit from its framework
        # deps when built as a dynamic framework under use_frameworks!, so the
        # linker never sees them and produces undefined-symbol errors for all
        # CLLocationManager / UIApplication references.
        config.build_settings['OTHER_LDFLAGS'] = '$(inherited) -framework CoreLocation -framework UIKit -framework Flutter'
      end
    end

    next unless target.name == 'geocoding_ios'

    target.source_build_phase.files.each do |build_file|
      next unless build_file.file_ref
      next unless build_file.file_ref.path&.end_with?('PrivacyInfo.xcprivacy')

      target.source_build_phase.remove_build_file(build_file)
    end
  end
end
