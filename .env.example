SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# RevenueCat SDK keys — get from RevenueCat Dashboard → Project Settings → API Keys
# iOS key starts with "appl_"   — required for iOS builds
# Android key starts with "goog_" — required for Android builds
REVENUE_CAT_IOS_KEY=
REVENUE_CAT_ANDROID_KEY=
